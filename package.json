{
  "name": "create-t3-turbo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @acme/auth generate",
    "db:push": "pnpm -F @acme/db push",
    "db:studio": "turbo -F @acme/db studio",
    "dev": "turbo watch dev --continue",
    "format": "turbo run format --continue",
    "format:fix": "turbo run format:fix --continue",
    "lint": "turbo run lint --continue",
    "lint:fix": "turbo run lint --continue -- --fix",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "prepare": "effect-language-service patch",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add"
  },
  "devDependencies": {
    "@acme/oxfmt-config": "workspace:*",
    "@acme/oxlint-config": "workspace:*",
    "@effect/language-service": "^0.85.1",
    "@turbo/gen": "^2.5.8",
    "@typescript/native-preview": "catalog:",
    "dotenv-cli": "^10.0.0",
    "effect-solutions": "^0.5.3",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^24.13.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0"
}
