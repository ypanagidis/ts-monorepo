{
  "name": "@acme/drizzle-effect-mysql2",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./driver": {
      "types": "./dist/driver.d.ts",
      "default": "./src/driver.ts"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./src/session.ts"
    },
    "./migrator": {
      "types": "./dist/migrator.d.ts",
      "default": "./src/migrator.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint --type-aware",
    "typecheck": "tsgo --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@effect/sql-mysql2": "4.0.0-beta.60",
    "drizzle-orm": "1.0.0-rc.2",
    "effect": "4.0.0-beta.60",
    "mysql2": "^3.14.1"
  },
  "devDependencies": {
    "@acme/oxfmt-config": "workspace:*",
    "@acme/oxlint-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@effect/sql-mysql2": ">=4.0.0-beta.58 || >=4.0.0",
    "drizzle-orm": "1.0.0-rc.2",
    "effect": ">=4.0.0-beta.58 || >=4.0.0",
    "mysql2": ">=3"
  }
}
