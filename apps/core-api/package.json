{
  "name": "@acme/core-api",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsgo --noEmit",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "pnpm with-env tsx watch src/index.ts",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint --type-aware",
    "start": "pnpm with-env tsx src/index.ts",
    "typecheck": "tsgo --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/api-contracts": "workspace:*",
    "@acme/db": "workspace:*",
    "@effect/platform-node": "catalog:",
    "effect": "4.0.0-beta.60",
    "ioredis": "^5.7.0"
  },
  "devDependencies": {
    "@acme/oxfmt-config": "workspace:*",
    "@acme/oxlint-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "dotenv-cli": "^10.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsx": "^4.20.6",
    "typescript": "catalog:"
  }
}
